# --- Runtime ---
NODE_ENV=development
PORT=3000
# Comma-separated list of allowed origins, or * for any (dev only).
CORS_ORIGINS=*

# --- Postgres (Drizzle) ---
DATABASE_URL=postgres://camflow:camflow@localhost:5432/camflow

# --- Redis (ioredis + BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Auth / JWT ---
# Access token signing secret (>= 32 chars). Generate: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-please-with-a-long-random-string-min-32
# Access token lifetime (e.g. 15m, 1h). Kept short — stored in RAM on the client.
JWT_ACCESS_TTL=15m
# Refresh token lifetime in days — stored in the iOS Keychain, rotated on use.
JWT_REFRESH_TTL_DAYS=60

# --- Social sign-in ---
# Apple Service/Bundle id used as the identity-token audience (optional but recommended).
APPLE_CLIENT_ID=
# Google OAuth client id used as the id-token audience (optional but recommended).
GOOGLE_CLIENT_ID=

# --- Invites ---
INVITE_WEB_HOST=camflow.app
INVITE_SCHEME=camflow

# --- Ops ---
# Basic-auth credentials guarding the Bull Board dashboard at /admin/queues.
BULL_BOARD_USER=admin
BULL_BOARD_PASSWORD=change-me

# --- Media storage (Phase 3) ---
# Public base URL of this API (used to build the upload-proxy URL returned in tickets).
API_PUBLIC_URL=http://localhost:3000
# 'local' writes to STORAGE_LOCAL_DIR (dev); 'bunny' uses Bunny.net Edge Storage.
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage
# Bunny.net Edge Storage (required when STORAGE_DRIVER=bunny)
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_HOST=storage.bunnycdn.com
BUNNY_STORAGE_PASSWORD=
# Bunny.net Pull Zone for signed CDN download URLs (token authentication)
BUNNY_PULL_ZONE_HOST=
BUNNY_PULL_ZONE_TOKEN=

# --- APNs push (Phase 4) ---
# All optional: remote push is a no-op until these are set. Token-based auth (.p8).
# Paste the .p8 contents (newlines may be \n-escaped on a single line).
APNS_KEY_P8=
APNS_KEY_ID=
APNS_TEAM_ID=
# The app's bundle id / APNs topic, e.g. com.camflow
APNS_BUNDLE_ID=
# 'true' targets api.push.apple.com, 'false' targets the sandbox.
APNS_PRODUCTION=false

# --- Ops / retention (Phase 5) ---
# Force OpenAPI docs at /docs in production (always on in dev).
SWAGGER_ENABLED=false
# Background retention jobs on the cleanup queue.
CLEANUP_ENABLED=true
# Hard-delete soft-deleted rows older than N days (must exceed the device purge).
TOMBSTONE_RETENTION_DAYS=30
# Drop expired/revoked refresh tokens older than N days.
REFRESH_TOKEN_GRACE_DAYS=7
